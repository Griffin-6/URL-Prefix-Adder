{
  "manifest_version": 3,
  "name": "前缀添加助手",
  "version": "1.0",
  "description": "请配合广告拦截插件",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "clipboardWrite",
    "contextMenus"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "线路配置"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}